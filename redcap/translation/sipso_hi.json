        {
            "id": "sipso_1_dress",
            "form": "sipso_questionnaire",
            "label": {
                "hash": "6525db3f29",
                "translation": "1. Since your stroke, how much difficulty do you have dressing yourself fully? / 1. स्ट्रोक के बाद, स्वयं को पूरी तरह से कपड़े पहनाने में आपको कितनी कठिनाई होती है? (एक संख्या पर घेरा लगाएँ)"
            },
            "enum": [
                {
                    "id": 4,
                    "hash": "5879f9637a",
                    "translation": "Not difficult at all / बिल्कुल कोई कठिनाई नहीं"
                },
                {
                    "id": 3,
                    "hash": "81c032b69f",
                    "translation": "Slightly difficult / थोड़ी कठिनाई"
                },
                {
                    "id": 2,
                    "hash": "9ee5601c1b",
                    "translation": "Moderately difficult / कुछ कठिनाई"
                },
                {
                    "id": 1,
                    "hash": "7d87008dc2",
                    "translation": "Very difficult / बहुत अधिक कठिनाई"
                },
                {
                    "id": 0,
                    "hash": "74dff10138",
                    "translation": "Unable to do it myself / मैं स्वयं को पूरी तरह से कपड़े नहीं पहन सकता"
                }
            ]
        },
